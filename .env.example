# Copy to .env and fill in values before running docker-compose or ingest scripts.
# Never commit .env to version control.

POSTGRES_USER=axion
POSTGRES_PASSWORD=axion
POSTGRES_DB=axion

# Full SQLAlchemy / psycopg2 connection URL (used by Alembic and ingest scripts)
AXION_DB_URL=postgresql://axion:axion@localhost:5432/axion

# API key for the REST + WebSocket interface.
# Leave ALL keys empty (or unset) to disable auth — useful for local dev and smoke tests.
# Clients: set X-API-Key header. WebSocket: pass ?api_key= query param.
#
# Legacy single-key mode (treated as manager — full access):
AXION_API_KEY=
#
# Role-based access control (RBAC). Three roles in order of privilege:
#   viewer   — read-only (GET endpoints)
#   operator — viewer + record decisions, control replay, what-if predictions
#   manager  — operator + change scenarios and any other write op
# Issue different keys to different users to enforce role boundaries.
AXION_API_KEY_VIEWER=
AXION_API_KEY_OPERATOR=
AXION_API_KEY_MANAGER=

# JWT-based auth (Bloque V). When AXION_JWT_SECRET is set, clients can
# exchange email + password at /api/auth/login for access + refresh tokens
# and use Authorization: Bearer <jwt> on subsequent requests. Users live
# in the `users` table — manage them with `python scripts/users.py`.
# Falls back to the API-key flow when no Bearer header is sent.
AXION_JWT_SECRET=
AXION_JWT_ACCESS_MINUTES=30
AXION_JWT_REFRESH_DAYS=7

# Rate limiting (Bloque W). Token-bucket per identity (user/api-key/ip).
# 0 disables. Default: 120 req/min with the burst capacity equal to per-min.
AXION_RATE_LIMIT_PER_MIN=120
AXION_RATE_LIMIT_BURST=

# Webhook notifications. Posts a JSON payload to AXION_WEBHOOK_URL whenever a
# recommendation crosses the urgency threshold. Leave URL empty to disable.
#   AXION_WEBHOOK_URGENCY: low | medium | high | critical (default: critical)
#   AXION_WEBHOOK_FORMAT:  axion (default, structured) | slack (text wrapper)
AXION_WEBHOOK_URL=
AXION_WEBHOOK_URGENCY=critical
AXION_WEBHOOK_TIMEOUT=5.0
AXION_WEBHOOK_FORMAT=axion

# Active process profile. Determines tag list, KPIs, scenarios, ML feature/target.
# Built-in profiles: "pilot" (CSTR + distillation column), "batch_reactor".
# Defaults to "pilot" when unset.
AXION_PROCESS_PROFILE=pilot

# OPC-UA integration. When enabled, the API server connects to a real plant
# (or any OPC-UA server like Kepware/Prosys/free open62541) and streams live
# tag values. Set ENABLED=true to activate.
AXION_OPCUA_ENABLED=false
# Path to YAML/JSON tag map (declares server endpoint + Axion-tag→node mapping).
# When unset, the in-memory PILOT_TAG_MAP is used.
AXION_OPCUA_TAG_MAP=
# Per-deployment overrides (handy for swapping endpoints without editing files).
AXION_OPCUA_ENDPOINT=
AXION_OPCUA_USERNAME=
AXION_OPCUA_PASSWORD=
# Security profile. "None" for open endpoints; for production use
# "Basic256Sha256" plus the cert + key paths.
AXION_OPCUA_SECURITY=None
AXION_OPCUA_CERT_PATH=
AXION_OPCUA_KEY_PATH=
# Optional node ID exposing the simulator's wall clock (used by the demo).
AXION_OPCUA_TIME_NODE=

# MLflow tracking URI. Leave unset to use local ./mlruns directory.
# Examples:
#   MLFLOW_TRACKING_URI=http://localhost:5000      # MLflow server
#   MLFLOW_TRACKING_URI=sqlite:///mlruns.db        # SQLite
MLFLOW_TRACKING_URI=
